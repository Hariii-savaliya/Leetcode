ython","time":"20\xc2\xa0hours, 32\xc2\xa0minutes","timestamp":1783755481,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2063611170/","is_pending":"Not Pending","title":"Kids With the Greatest Number of Candies","memory":"12.2 MB","code":"class Solution(object):\\n    def kidsWithCandies(self, candies, extraCandies):\\n        \\"\\"\\"\\n        :type candies: List[int]\\n        :type extraCandies: int\\n        :rtype: List[bool]\\n        \\"\\"\\"\\n        m = max(candies)\\n        for i in range(len(candies)):\\n            if (candies[i]+extraCandies) >= m:\\n                candies[i] = True\\n            else:\\n                candies[i] = False\\n        return candies\\n\\n\\n        ","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"kids-with-the-greatest-number-of-candies","has_notes":false,"flag_type":1,"frontend_id":45},{"id":2063601841,"question_id":1603,"lang":"python","lang_name":"Python","time":"20\xc2\xa0hours, 43\xc2\xa0minutes","timestamp":1783754824,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2063601841/","is_pending":"Not Pending","title":"Running Sum of 1d Array","memory":"12.4 MB","code":"class Solution(object):\\n    def runningSum(self, nums):\\n        \\"\\"\\"\\n        :type nums: List[int]\\n        :rtype: List[int]\\n        \\"\\"\\"\\n        for i in range(1,len(nums)):\\n            nums[i]+=nums[i-1]\\n        return nums","compare_result":"111111111111111111111111111111111111111111111111111111","title_slug":"running-sum-of-1d-array","has_notes":false,"flag_type":1,"frontend_id":44},{"id":2063592285,"question_id":121,"lang":"python","lang_name":"Python","time":"20\xc2\xa0hours, 53\xc2\xa0minutes","timestamp":1783754183,"status":10,"status_display":"Accepted","runtime":"132 ms","url":"/submissions/detail/2063592285/","is_pending":"Not Pending","title":"Best Time to Buy and Sell Stock","memory":"18.9 MB","code":"class Solution(object):\\n    def maxProfit(self, prices):\\n        \\"\\"\\"\\n        :type prices: List[int]\\n        :rtype: int\\n        \\"\\"\\"\\n        minprice = 10**4\\n        maxprofit = 0\\n        for price in prices:\\n            minprice = min(minprice,price)\\n            maxprofit = max(maxprofit,price-minprice)\\n        return maxprofit\\n        ","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"best-time-to-buy-and-sell-stock","has_notes":false,"flag_type":1,"frontend_id":43},{"id":2063380302,"question_id":21,"lang":"python","lang_name":"Python","time":"1\xc2\xa0day, 2\xc2\xa0hours","timestamp":1783734557,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2063380302/","is_pending":"Not Pending","title":"Merge Two Sorted Lists","memory":"12.3 MB","code":"# Definition for singly-linked list.\\n# class ListNode(object):\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution(object):\\n    def mergeTwoLists(self, list1, list2):\\n        \\"\\"\\"\\n        :type list1: Optional[ListNode]\\n        :type list2: Optional[ListNode]\\n        :rtype: Optional[ListNode]\\n        \\"\\"\\"\\n        p1 = list1\\n        p2 = list2\\n        result = ListNode(0)\\n        curr = result\\n        while p1 and p2:\\n            if p1.val <= p2.val:\\n                curr.next = p1\\n                p1 = p1.next\\n            else:\\n                curr.next = p2\\n                p2 = p2.next\\n            curr = curr.next\\n        if p1:\\n            curr.next = p1\\n        else:\\n            curr.next = p2\\n        return result.next\\n\\n                \\n        \\n        ","compare_result":"11111111